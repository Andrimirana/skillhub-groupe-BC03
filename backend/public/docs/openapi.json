{
  "openapi": "3.0.3",
  "info": {
    "title": "API Dashboard Formateur",
    "version": "1.0.0",
    "description": "API Laravel pour authentification JWT et gestion des formations du formateur."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8000/api"
    }
  ],
  "paths": {
    "/inscription": {
      "post": {
        "summary": "Inscription utilisateur",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "nom",
                  "email",
                  "mot_de_passe",
                  "role"
                ],
                "properties": {
                  "nom": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "mot_de_passe": {
                    "type": "string",
                    "minLength": 8
                  },
                  "role": {
                    "type": "string",
                    "enum": [
                      "formateur",
                      "apprenant"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Inscription réussie"
          },
          "422": {
            "description": "Données invalides"
          }
        }
      }
    },
    "/connexion": {
      "post": {
        "summary": "Connexion utilisateur",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "mot_de_passe"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "mot_de_passe": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Connexion réussie"
          },
          "401": {
            "description": "Identifiants invalides"
          }
        }
      }
    },
    "/profil": {
      "get": {
        "summary": "Profil connecté",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Données du formateur"
          },
          "401": {
            "description": "Non authentifié"
          }
        }
      }
    },
    "/deconnexion": {
      "post": {
        "summary": "Déconnexion",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Déconnecté"
          }
        }
      }
    },
    "/formations": {
      "get": {
        "summary": "Liste des formations (formateur: ses formations, apprenant: toutes les formations)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Liste des formations"
          }
        }
      },
      "post": {
        "summary": "Créer une formation",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "titre",
                  "description",
                  "date",
                  "price",
                  "duration",
                  "level"
                ],
                "properties": {
                  "titre": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "date": {
                    "type": "string",
                    "format": "date"
                  },
                  "statut": {
                    "type": "string"
                  },
                  "price": {
                    "type": "number",
                    "format": "double"
                  },
                  "duration": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "level": {
                    "type": "string",
                    "enum": [
                      "beginner",
                      "intermediaire",
                      "advanced"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Formation créée"
          },
          "403": {
            "description": "Réservé aux formateurs"
          }
        }
      }
    },
    "/formations/{id}": {
      "put": {
        "summary": "Modifier une formation du formateur connecté",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "titre",
                  "description",
                  "date"
                ],
                "properties": {
                  "titre": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "date": {
                    "type": "string",
                    "format": "date"
                  },
                  "statut": {
                    "type": "string"
                  },
                  "price": {
                    "type": "number",
                    "format": "double"
                  },
                  "duration": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "level": {
                    "type": "string",
                    "enum": [
                      "beginner",
                      "intermediaire",
                      "advanced"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Formation modifiée"
          },
          "403": {
            "description": "Réservé aux formateurs ou formation non autorisée pour ce formateur"
          },
          "404": {
            "description": "Formation introuvable"
          }
        }
      },
      "delete": {
        "summary": "Supprimer une formation du formateur connecté",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Formation supprimée"
          },
          "403": {
            "description": "Réservé aux formateurs ou formation non autorisée pour ce formateur"
          },
          "404": {
            "description": "Formation introuvable"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}